{
  "name": "worldcup-atlas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@8.15.1",
  "scripts": {
    "assets:icons": "tsx scripts/assets/generate-icons.ts",
    "data:download": "tsx scripts/import/download-fjelstul.ts",
    "data:import": "tsx scripts/import/import-fjelstul.ts",
    "data:inspect": "tsx scripts/import/inspect-fjelstul.ts",
    "data:verify": "tsx scripts/verify/verify-counts.ts",
