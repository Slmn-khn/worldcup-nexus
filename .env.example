# WORLDCUP Nexus — local environment template
# Copy to .env and adjust if needed: cp .env.example .env
# These values match docker-compose.yml for LOCAL DEVELOPMENT ONLY —
# never reuse these credentials or this Meilisearch key in production.
# For production placeholders see .env.production.example.

# Server-only. PostgreSQL connection string (Prisma driver adapter).
DATABASE_URL="postgresql://worldcup:worldcup@localhost:5432/worldcup_atlas?schema=public"
# Server-only. Direct (non-pooled) connection for migrations; same as
# DATABASE_URL locally. Used only if you wire a pooled setup (see
# docs/DATABASE_PRODUCTION.md).
DIRECT_URL="postgresql://worldcup:worldcup@localhost:5432/worldcup_atlas?schema=public"

# Server-only. The browser never talks to Meilisearch directly.
MEILISEARCH_HOST="http://localhost:7700"
# Server-only. Locally this is the docker-compose master key; in production
# the app should hold a scoped search-only key (docs/MEILISEARCH_PRODUCTION.md).
MEILISEARCH_API_KEY="worldcup_atlas_master_key"

# Public (inlined into the client bundle — safe by design, never a secret).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ── 2026 schedule & scores fixture pipeline (server-only) ──────────────────
# All provider fetches run server-side; the browser never talks to these.
# Never expose these as NEXT_PUBLIC_* — they must stay server-only.
#
# OpenFootball is the STABLE BASELINE provider (no API key). Schedule, venues,
# groups, basic results. This is all production needs.
OPENFOOTBALL_2026_URL="https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json"
#
# worldcup26 is an OPTIONAL live/current provider. Leave blank to disable — the
# default mode below does not use it. Only enable it after verifying the
# endpoint. To test it locally, set the base URL (host only; the "/get/games"
# path is appended automatically) and switch to openfootball-first:
#   WORLDCUP26_API_BASE_URL="https://worldcup26.ir"
#   FIXTURE_SYNC_PROVIDER_MODE="openfootball-first"
WORLDCUP26_API_BASE_URL=""
#
# Provider mode: openfootball-only | worldcup26-only | openfootball-first |
# live-first. Production default is openfootball-only (worldcup26 never called).
# Missing/invalid values fall back to openfootball-only.
FIXTURE_SYNC_PROVIDER_MODE="openfootball-only"
#
# Shared secret protecting the cron/manual sync route. Set a long random value
# in production; an empty value disables the route (fail closed).
CRON_SECRET=""