// WorldCup Atlas — initial schema.
// Prisma 7: the connection URL lives in prisma.config.ts (datasource.url),
// and the client is generated into src/generated/prisma via the
// `prisma-client` generator (prisma-client-js was removed in Prisma 7).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CardType {
  YELLOW
  SECOND_YELLOW
  RED
}

// User feedback & suggestions. Submissions are PRIVATE and moderated by
// default — nothing here is ever published automatically. Abuse-prevention
// signals (IP / user agent) are stored only as salted hashes, never raw.
enum FeedbackType {
  BUG_REPORT
  INCORRECT_DATA
  FEATURE_REQUEST
  DESIGN_FEEDBACK
  MISSING_DATA
  SCHEDULE_ISSUE
  OTHER
}

enum FeedbackStatus {
  PENDING
  REVIEWED
  PLANNED
  IN_PROGRESS
  RESOLVED
  REJECTED
  SPAM
}

enum FeedbackPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PenaltyKickType {
  IN_MATCH
  SHOOTOUT
}

// Live-fixture pipeline (2026 schedule & scores). Distinct from the historical
// Match model: Fixture holds source-attributed, syncable provider rows for the
// current/upcoming tournament — never silently merged into the curated archive.
enum FixtureStatus {
  SCHEDULED
  LIVE
  HALF_TIME
  FINISHED
  POSTPONED
  CANCELLED
  UNKNOWN
}

enum FixtureSource {
  OPENFOOTBALL
  WORLDCUP26
  MANUAL
}

// ---------------------------------------------------------------------------
// Media asset layer (Phase 1). Media is an OPTIONAL enhancement on top of the
// football data — nothing here is required for a page to render. See
// docs/MEDIA_ASSET_STRATEGY.md and docs/MEDIA_LICENSE_POLICY.md.
// ---------------------------------------------------------------------------

enum MediaEntityType {
  PLAYER
  COUNTRY
  TOURNAMENT
  MATCH
  RECORD
  ICONIC_MOMENT
  STADIUM
  GENERIC
}

enum MediaAssetType {
  PORTRAIT
  FLAG
  HERO
  POSTER
  THUMBNAIL
  BACKGROUND
  EVENT_COVER
  TROPHY
  STADIUM
  SILHOUETTE
  FALLBACK
}

enum MediaSourceProvider {
  LOCAL
  WIKIMEDIA_COMMONS
  WIKIDATA
  CLOUDINARY
  SUPABASE_STORAGE
  GENERATED
  MANUAL
  OTHER
}

enum MediaLicenseType {
  PUBLIC_DOMAIN
  CC0
  CC_BY
  CC_BY_SA
  CC_BY_NC
  RIGHTS_RESERVED
  GENERATED_OWNED
  UNKNOWN
}

enum MediaAssetStatus {
  CANDIDATE
  APPROVED
  REJECTED
  NEEDS_REVIEW
  ARCHIVED
}

model Tournament {
  id           String    @id @default(cuid())
  sourceId     String?   @unique
  year         Int       @unique
  name         String
  slug         String    @unique
  hostName     String?
  startDate    DateTime?
  endDate      DateTime?
  teamsCount   Int?
  matchesCount Int?
  goalsCount   Int?

  // Resolved after import; plain scalars to avoid circular relation setup.
  winnerTeamId   String?
  runnerUpTeamId String?

  // Optional visual-theme hints (Phase 1 media layer). All nullable — never
  // required for a tournament to render.
  themeColorPrimary   String?
  themeColorSecondary String?
  visualTheme         String?

  teams        Team[]
  matches      Match[]
  squadPlayers SquadPlayer[]
  awards       Award[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([year])
}

model Country {
  id        String  @id @default(cuid())
  sourceId  String? @unique
  name      String
  slug      String  @unique
  code      String?
  fifaCode  String?
  flagEmoji String?

  // Optional flag/identity codes (Phase 1 media layer). Used to resolve a
  // CSS flag-icons code; all nullable.
  iso2Code String?
  iso3Code String?
  flagCode String?

  teams   Team[]
  players Player[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id           String  @id @default(cuid())
  sourceId     String? @unique
  tournamentId String
  countryId    String?
  name         String
  slug         String
  code         String?

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  country    Country?   @relation(fields: [countryId], references: [id])

  homeMatches    Match[] @relation("MatchHomeTeam")
  awayMatches    Match[] @relation("MatchAwayTeam")
  winningMatches Match[] @relation("MatchWinningTeam")

  goals         Goal[]
  bookings      Booking[]
  substitutions Substitution[]
  penaltyKicks  PenaltyKick[]
  squadPlayers  SquadPlayer[]
  awards        Award[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tournamentId, slug])
  @@index([countryId])
}

model Player {
  id          String    @id @default(cuid())
  sourceId    String?   @unique
  name        String
  slug        String    @unique
  countryId   String?
  position    String?
  dateOfBirth DateTime?

  // Optional external identifiers (Phase 1 media layer) used to locate
  // license-cleared portraits; all nullable.
  wikidataId      String?
  commonsCategory String?

  country Country? @relation(fields: [countryId], references: [id])

  squadPlayers     SquadPlayer[]
  goals            Goal[]         @relation("GoalScorer")
  assists          Goal[]         @relation("GoalAssist")
  bookings         Booking[]
  substitutionsIn  Substitution[] @relation("SubstitutionPlayerIn")
  substitutionsOut Substitution[] @relation("SubstitutionPlayerOut")
  penaltyKicks     PenaltyKick[]
  awards           Award[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([countryId])
}

model Stadium {
  id       String  @id @default(cuid())
  sourceId String? @unique
  name     String
  slug     String  @unique
  city     String?
  country  String?

  matches Match[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Referee {
  id       String  @id @default(cuid())
  sourceId String? @unique
  name     String
  slug     String  @unique
  country  String?

  matches Match[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id            String    @id @default(cuid())
  sourceId      String?   @unique
  tournamentId  String
  homeTeamId    String
  awayTeamId    String
  winningTeamId String?
  slug          String    @unique
  stage         String
  matchDate     DateTime?
  matchNumber   Int?
  stadiumId     String?
  refereeId     String?
  attendance    Int?

  homeScore          Int     @default(0)
  awayScore          Int     @default(0)
  homeScorePenalties Int?
  awayScorePenalties Int?
  decidedByPenalties Boolean @default(false)

  tournament  Tournament @relation(fields: [tournamentId], references: [id])
  homeTeam    Team       @relation("MatchHomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team       @relation("MatchAwayTeam", fields: [awayTeamId], references: [id])
  winningTeam Team?      @relation("MatchWinningTeam", fields: [winningTeamId], references: [id])
  stadium     Stadium?   @relation(fields: [stadiumId], references: [id])
  referee     Referee?   @relation(fields: [refereeId], references: [id])

  goals         Goal[]
  bookings      Booking[]
  substitutions Substitution[]
  penaltyKicks  PenaltyKick[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([stage])
  @@index([matchDate])
}

model SquadPlayer {
  id           String  @id @default(cuid())
  tournamentId String
  teamId       String
  playerId     String
  shirtNumber  Int?
  position     String?
  isCaptain    Boolean @default(false)

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  team       Team       @relation(fields: [teamId], references: [id])
  player     Player     @relation(fields: [playerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tournamentId, teamId, playerId])
  @@index([teamId])
  @@index([playerId])
}

model Goal {
  id             String  @id @default(cuid())
  sourceId       String? @unique
  matchId        String
  teamId         String
  playerId       String
  assistPlayerId String?
  minute         Int?
  stoppageMinute Int?
  isOwnGoal      Boolean @default(false)
  isPenalty      Boolean @default(false)

  match        Match   @relation(fields: [matchId], references: [id])
  team         Team    @relation(fields: [teamId], references: [id])
  player       Player  @relation("GoalScorer", fields: [playerId], references: [id])
  assistPlayer Player? @relation("GoalAssist", fields: [assistPlayerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([teamId])
  @@index([playerId])
  @@index([assistPlayerId])
}

model Booking {
  id             String   @id @default(cuid())
  sourceId       String?  @unique
  matchId        String
  teamId         String
  playerId       String
  cardType       CardType
  minute         Int?
  stoppageMinute Int?

  match  Match  @relation(fields: [matchId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([teamId])
  @@index([playerId])
  @@index([cardType])
}

model Substitution {
  id             String  @id @default(cuid())
  sourceId       String? @unique
  matchId        String
  teamId         String
  playerInId     String?
  playerOutId    String?
  minute         Int?
  stoppageMinute Int?

  match     Match   @relation(fields: [matchId], references: [id])
  team      Team    @relation(fields: [teamId], references: [id])
  playerIn  Player? @relation("SubstitutionPlayerIn", fields: [playerInId], references: [id])
  playerOut Player? @relation("SubstitutionPlayerOut", fields: [playerOutId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([teamId])
  @@index([playerInId])
  @@index([playerOutId])
}

model PenaltyKick {
  id             String          @id @default(cuid())
  sourceId       String?         @unique
  matchId        String
  teamId         String
  playerId       String?
  type           PenaltyKickType
  order          Int?
  minute         Int?
  stoppageMinute Int?
  converted      Boolean
  isSaved        Boolean?
  isMissed       Boolean?

  match  Match   @relation(fields: [matchId], references: [id])
  team   Team    @relation(fields: [teamId], references: [id])
  player Player? @relation(fields: [playerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([teamId])
  @@index([playerId])
  @@index([type])
}

model Award {
  id           String  @id @default(cuid())
  sourceId     String? @unique
  tournamentId String
  playerId     String?
  teamId       String?
  name         String
  description  String?

  tournament Tournament @relation(fields: [tournamentId], references: [id])
  player     Player?    @relation(fields: [playerId], references: [id])
  team       Team?      @relation(fields: [teamId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId])
  @@index([playerId])
  @@index([teamId])
}

// One row per (provider, source match id) for the 2026 schedule & scores
// feature. The canonical view per logical match is computed at read time
// (see src/server/fixtures/normalize.ts selectCanonicalFixtures) — provider
// rows are kept separate so a flaky live source never corrupts the baseline.
model Fixture {
  id String @id @default(cuid())

  tournamentYear Int
  source         FixtureSource
  sourceId       String?

  matchNumber Int?
  round       String?
  stage       String?
  groupName   String?

  kickoffAtUtc     DateTime?
  kickoffDateLabel String?
  kickoffTimeLabel String?
  venueTimeZone    String?

  homeTeamName String?
  awayTeamName String?
  homeTeamSlug String?
  awayTeamSlug String?
  homeTeamCode String?
  awayTeamCode String?
  homeTeamFlag String?
  awayTeamFlag String?

  homeScore        Int?
  awayScore        Int?
  homePenaltyScore Int?
  awayPenaltyScore Int?

  status FixtureStatus @default(UNKNOWN)

  venueName   String?
  cityName    String?
  countryName String?

  sourcePriority  Int       @default(100)
  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime  @default(now())
  rawPayload      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, sourceId])
  @@index([tournamentYear])
  @@index([kickoffAtUtc])
  @@index([status])
  @@index([groupName])
  @@index([stage])
  @@index([homeTeamSlug])
  @@index([awayTeamSlug])
}

// Audit trail for each provider sync attempt — never leaks provider secrets.
model FixtureSyncLog {
  id String @id @default(cuid())

  provider        String
  status          String
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  recordsFetched  Int       @default(0)
  recordsUpserted Int       @default(0)
  errorMessage    String?
  metadata        Json?

  createdAt DateTime @default(now())

  @@index([provider])
  @@index([status])
  @@index([startedAt])
}

// Verbatim copy of every imported source row, kept for auditing and
// re-normalization without re-downloading source data.
model RawSourceRecord {
  id         String   @id @default(cuid())
  source     String
  entityType String
  sourceId   String?
  payload    Json
  importedAt DateTime @default(now())

  @@index([source, entityType])
  @@index([sourceId])
}

// One row per image. Holds provider/source URLs, dimensions, render hints,
// full license + attribution metadata, and a review status. Only APPROVED
// assets are ever returned by the public query layer.
model MediaAsset {
  id String @id @default(cuid())

  assetType MediaAssetType
  status    MediaAssetStatus @default(CANDIDATE)

  provider        MediaSourceProvider
  providerAssetId String?
  sourcePageUrl   String?
  originalUrl     String?
  storageUrl      String?
  optimizedUrl    String?

  title       String?
  description String?
  altText     String?

  width       Int?
  height      Int?
  blurDataUrl String?

  dominantColor String?
  focalX        Float?
  focalY        Float?

  licenseType     MediaLicenseType @default(UNKNOWN)
  licenseName     String?
  licenseUrl      String?
  creatorName     String?
  creditText      String?
  attributionHtml String?

  rawMetadata Json?

  reviewedAt      DateTime?
  reviewedBy      String?
  rejectionReason String?

  entityLinks EntityMedia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetType])
  @@index([status])
  @@index([provider])
  @@index([licenseType])
}

// Links a MediaAsset to a domain entity (by type + id) for a given usage role.
model EntityMedia {
  id String @id @default(cuid())

  entityType MediaEntityType
  entityId   String

  mediaAssetId String
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  usage     MediaAssetType
  priority  Int            @default(100)
  isPrimary Boolean        @default(false)

  caption    String?
  displayAlt String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([mediaAssetId])
  @@index([usage])
  @@index([isPrimary])
}

// Audit row per media import/seed run.
model MediaImportJob {
  id String @id @default(cuid())

  provider   MediaSourceProvider
  entityType MediaEntityType
  entityId   String?
  query      String?

  status          String
  recordsFound    Int    @default(0)
  recordsImported Int    @default(0)

  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  errorMessage String?
  metadata     Json?

  createdAt DateTime @default(now())

  @@index([provider])
  @@index([entityType, entityId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// User feedback & suggestions. Every submission starts PRIVATE + moderated
// (status PENDING) — never shown publicly and never acted on automatically.
// Sensitive abuse signals (IP / user agent) are stored only as salted hashes.
// ---------------------------------------------------------------------------
model FeedbackSubmission {
  id String @id @default(cuid())

  type     FeedbackType
  status   FeedbackStatus   @default(PENDING)
  priority FeedbackPriority @default(MEDIUM)

  title   String
  message String

  // Optional context the submitter can attach (all nullable).
  pageUrl        String?
  tournamentYear Int?
  countryName    String?
  playerName     String?
  matchLabel     String?

  // Optional contact details (never required).
  email String?
  name  String?

  // Abuse-prevention signals — salted SHA-256 hashes only, never raw values.
  ipHash          String?
  userAgentHash   String?
  fingerprintHash String?

  turnstileSuccess Boolean @default(false)
  spamScore        Int     @default(0)
  spamReasons      Json?

  duplicateHash String?
  duplicateOfId String?

  adminNotes String?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events FeedbackEvent[]

  @@index([type])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([duplicateHash])
}

// Append-only audit trail for moderation actions on a submission.
model FeedbackEvent {
  id String @id @default(cuid())

  feedbackId String
  feedback   FeedbackSubmission @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  action   String
  note     String?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([feedbackId])
  @@index([action])
  @@index([createdAt])
}
