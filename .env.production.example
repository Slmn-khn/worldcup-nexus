# WORLDCUP Nexus — production environment template
#
# PLACEHOLDERS ONLY. Never commit real values: set them in the hosting
# platform's environment settings (e.g. Vercel project env vars).
# Full guidance: docs/DEPLOYMENT.md, docs/PRODUCTION_RUNBOOK.md.

# --- Database (server-only secrets) ---------------------------------------
# PostgreSQL connection string used by the app at runtime and by
# `pnpm db:deploy` / data import. With a pooled provider (e.g. Supabase
# with PgBouncer), point DATABASE_URL at the POOLED endpoint.
DATABASE_URL=""
# Direct (non-pooled) connection for migrations/import. Same value as
# DATABASE_URL if your provider has no separate pooler endpoint.
DIRECT_URL=""

# --- Meilisearch (server-only secrets) -------------------------------------
# HTTPS endpoint of the production Meilisearch instance. Never expose the
# instance directly to the public internet without keys; the browser only
# ever talks to /api/search.
MEILISEARCH_HOST=""
# Key the APP uses at runtime. Use a SCOPED, SEARCH-ONLY key here whenever
# the deployment supports it. The admin/master key is used only for
# `pnpm search:index` from a trusted admin environment — never in the app
# runtime and never in browser/client code.
MEILISEARCH_API_KEY=""

# --- Public configuration (safe to expose) ---------------------------------
# Canonical production URL. NEXT_PUBLIC_* values are inlined into the
# client bundle — never put secrets in NEXT_PUBLIC variables.
NEXT_PUBLIC_SITE_URL="https://your-production-domain.com"

# --- Platform ---------------------------------------------------------------
# Most platforms (Vercel) set NODE_ENV=production automatically; it gates
# the dev-only endpoint, enables HSTS, and disables debug error detail.
NODE_ENV="production"
